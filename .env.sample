OPENAI_API_KEY="your-api-key"
OPENAI_API_BASE="https://openrouter.ai/api/v1"
OPENAI_DEFAULT_MODEL="google/gemini-2.5-flash"

# --- LLM response cache (exact-match, not semantic) ---
# Caches identical chat completion requests locally. Handy while iterating
# on prompts/extractors against the same document. Cached responses are
# reported with cost=0 in ExtractionResult.
LLM_CACHE_ENABLED="true"
LLM_CACHE_BACKEND="sqlite"          # "sqlite" or "memory"
LLM_CACHE_PATH=".cache/llm_cache.db"
LLM_CACHE_MAX_SIZE_MB="500"         # auto-clear DB once it exceeds this size
LLM_CACHE_HIT_THRESHOLD_S="0.5"     # invoke() wall-time below which we treat a call as a cache hit
